<script>
var sfWizard = {
    currentStep: 1,
    zones: [],
    provisioning: false,
    formData: {}
};

/* ===== Navigation ===== */
function sfGoStep(n) {
    document.querySelectorAll('.sf-wizard-panel').forEach(function(p) { p.classList.remove('active'); });
    document.getElementById('sf-panel-' + n).classList.add('active');

    document.querySelectorAll('.sf-wizard-step').forEach(function(s, i) {
        s.classList.remove('active', 'done');
        if (i + 1 < n) s.classList.add('done');
        if (i + 1 === n) s.classList.add('active');
    });

    sfWizard.currentStep = n;
}

/* ===== Auto-set store code from Maho store view ===== */
function sfStoreViewChange() {
    var sel = document.getElementById('sf-maho-store');
    var opt = sel.options[sel.selectedIndex];
    var code = opt ? (opt.dataset.code || '') : '';
    document.getElementById('sf-store-code').value = code;
}

/* ===== Live domain preview ===== */
function sfUpdatePreview() {
    var subdomain = document.getElementById('sf-subdomain').value.trim();
    var zoneSelect = document.getElementById('sf-zone');
    var zoneName = zoneSelect.options[zoneSelect.selectedIndex] ? zoneSelect.options[zoneSelect.selectedIndex].dataset.name || '' : '';
    var preview = document.getElementById('sf-domain-preview');

    if (subdomain && zoneName) {
        preview.textContent = 'https://' + subdomain + '.' + zoneName;
        preview.style.display = 'inline-block';
    } else {
        preview.style.display = 'none';
    }
}

/* ===== Load zones on page load ===== */
async function sfLoadZones() {
    try {
        var r = await mahoFetch('<?php echo $this->getListZonesUrl() ?>');
        var select = document.getElementById('sf-zone');
        select.innerHTML = '<option value=""><?php echo $this->jsQuoteEscape($this->__('-- Select Zone --')) ?></option>';

        if (r.success && r.zones) {
            sfWizard.zones = r.zones;
            r.zones.forEach(function(z) {
                var opt = document.createElement('option');
                opt.value = z.id;
                opt.textContent = z.name;
                opt.dataset.name = z.name;
                select.appendChild(opt);
            });
        }
    } catch (e) {
        var select = document.getElementById('sf-zone');
        select.innerHTML = '<option value=""><?php echo $this->jsQuoteEscape($this->__('Failed to load zones')) ?></option>';
    }

    select.addEventListener('change', sfUpdatePreview);
}

/* ===== Validation (Step 1 -> 2) ===== */
async function sfValidate() {
    var storeName = document.getElementById('sf-store-name').value.trim();
    var storeCode = document.getElementById('sf-store-code').value.trim();
    var subdomain = document.getElementById('sf-subdomain').value.trim();
    var zoneSelect = document.getElementById('sf-zone');
    var zoneId = zoneSelect.value;
    var zoneName = zoneSelect.options[zoneSelect.selectedIndex] ? zoneSelect.options[zoneSelect.selectedIndex].dataset.name || '' : '';
    var domainType = document.getElementById('sf-domain-type').value;
    var mahoStoreId = document.getElementById('sf-maho-store').value;

    if (!storeName || !storeCode || !subdomain || !zoneId || !mahoStoreId) {
        alert('<?php echo $this->jsQuoteEscape($this->__('Please fill in all fields.')) ?>');
        return;
    }

    sfWizard.formData = {
        store_name: storeName,
        store_code: storeCode,
        subdomain: subdomain,
        zone_id: zoneId,
        zone_name: zoneName,
        domain_type: domainType,
        maho_store_id: mahoStoreId
    };

    sfGoStep(2);

    var resultsEl = document.getElementById('sf-validation-results');
    var errorEl = document.getElementById('sf-validation-error');
    var provBtn = document.getElementById('sf-provision-btn');

    resultsEl.innerHTML = '<div style="color:#888;font-size:12px;"><?php echo $this->jsQuoteEscape($this->__('Validating...')) ?></div>';
    errorEl.style.display = 'none';
    provBtn.style.display = 'none';

    try {
        var r = await mahoFetch('<?php echo $this->getValidateUrl() ?>', {
            method: 'POST',
            body: buildFormBody(sfWizard.formData)
        });

        if (!r.success || !r.checks) {
            errorEl.textContent = r.error || r.message || 'Validation failed — unexpected response.';
            errorEl.style.display = 'block';
            resultsEl.innerHTML = '';
            return;
        }

        var html = '';
        r.checks.forEach(function(c) {
            var icon = c.pass ? '<span class="sf-check-icon sf-check-pass">&#10003;</span>' : '<span class="sf-check-icon sf-check-fail">&#10007;</span>';
            var cls = c.pass ? 'sf-check-pass' : 'sf-check-fail';
            html += '<div class="sf-check-item ' + cls + '">' + icon + ' ' + escapeHtml(c.label);
            if (!c.pass && c.error) html += ' &mdash; ' + escapeHtml(c.error);
            html += '</div>';
        });
        resultsEl.innerHTML = html;

        if (r.all_pass) {
            provBtn.style.display = 'inline-block';
        }
    } catch (e) {
        errorEl.textContent = e.message || 'Request failed';
        errorEl.style.display = 'block';
        resultsEl.innerHTML = '';
    }
}

/* ===== Provision (Step 2 -> 3) ===== */
async function sfProvision() {
    if (sfWizard.provisioning) return;
    sfWizard.provisioning = true;

    sfGoStep(3);

    var barEl = document.getElementById('sf-prov-bar');
    var percentEl = document.getElementById('sf-prov-percent');
    var labelEl = document.getElementById('sf-prov-label');
    var stepInfoEl = document.getElementById('sf-prov-step-info');
    var errorEl = document.getElementById('sf-prov-error');
    var actionsEl = document.getElementById('sf-prov-actions');

    barEl.style.width = '0%';
    barEl.style.background = '#3d6d93';
    percentEl.textContent = '0%';
    labelEl.textContent = '<?php echo $this->jsQuoteEscape($this->__('Initializing...')) ?>';
    stepInfoEl.textContent = '';
    errorEl.style.display = 'none';
    actionsEl.style.display = 'none';

    try {
        var r = await mahoFetch('<?php echo $this->getProvisionUrl() ?>', {
            method: 'POST',
            body: buildFormBody(sfWizard.formData)
        });

        if (!r.success) {
            showProvError(r.error || 'Failed to initialize provisioning');
            return;
        }

        labelEl.textContent = r.first_step + '...';
        stepInfoEl.textContent = 'Step 1 of ' + r.total_steps;

        await runProvSteps();
    } catch (e) {
        showProvError(e.message || 'Request failed');
    }

    async function runProvSteps() {
        while (true) {
            try {
                var r = await mahoFetch('<?php echo $this->getProvisionStepUrl() ?>', { method: 'POST' });

                if (!r.success) {
                    showProvError((r.error || 'Step failed') + ' (Step ' + r.step + '/' + r.total + ': ' + r.label + ')');
                    if (r.can_rollback) {
                        actionsEl.style.display = 'flex';
                    }
                    return;
                }

                barEl.style.width = r.percent + '%';
                percentEl.textContent = r.percent + '%';
                stepInfoEl.textContent = 'Step ' + r.step + ' of ' + r.total;

                if (r.complete) {
                    labelEl.textContent = '<?php echo $this->jsQuoteEscape($this->__('Provisioning complete!')) ?>';
                    barEl.style.background = '#4caf50';
                    sfWizard.provisioning = false;

                    // Show complete panel
                    sfShowComplete(r);
                    return;
                } else {
                    labelEl.textContent = r.next_label + '...';
                }
            } catch (e) {
                showProvError(e.message || 'Request failed');
                actionsEl.style.display = 'flex';
                return;
            }
        }
    }

    function showProvError(msg) {
        errorEl.textContent = msg;
        errorEl.style.display = 'block';
        barEl.style.background = '#e53935';
        sfWizard.provisioning = false;
    }
}

/* ===== Complete (Step 4) ===== */
function sfShowComplete(data) {
    setTimeout(function() { sfGoStep(4); }, 500);

    var html = '<dl>';
    html += '<dt><?php echo $this->jsQuoteEscape($this->__('Store URL')) ?></dt>';
    html += '<dd><a href="' + escapeAttr(data.store_url) + '" target="_blank">' + escapeHtml(data.store_url) + '</a></dd>';
    html += '<dt><?php echo $this->jsQuoteEscape($this->__('Store Code')) ?></dt>';
    html += '<dd><code>' + escapeHtml(data.store_code) + '</code></dd>';
    html += '<dt><?php echo $this->jsQuoteEscape($this->__('DNS Status')) ?></dt>';
    html += '<dd>' + (data.domain_type === 'managed' ? '<?php echo $this->jsQuoteEscape($this->__('Auto-configured')) ?>' : '<?php echo $this->jsQuoteEscape($this->__('Manual setup required')) ?>') + '</dd>';
    html += '</dl>';
    document.getElementById('sf-complete-info').innerHTML = html;

    if (data.domain_type === 'external' && data.cname_target) {
        var cnameHtml = '<div class="sf-cname-box">';
        cnameHtml += '<strong><?php echo $this->jsQuoteEscape($this->__('DNS Configuration Required')) ?></strong><br/><br/>';
        cnameHtml += '<?php echo $this->jsQuoteEscape($this->__('Add a CNAME record to your DNS provider:')) ?><br/><br/>';
        cnameHtml += '<strong>Name:</strong> <code id="sf-cname-name">' + escapeHtml(data.cname_name) + '</code> ';
        cnameHtml += '<button type="button" class="sf-copy-btn" onclick="sfCopy(\'sf-cname-name\')">Copy</button><br/>';
        cnameHtml += '<strong>Target:</strong> <code id="sf-cname-target">' + escapeHtml(data.cname_target) + '</code> ';
        cnameHtml += '<button type="button" class="sf-copy-btn" onclick="sfCopy(\'sf-cname-target\')">Copy</button>';
        cnameHtml += '</div>';
        document.getElementById('sf-cname-instructions').innerHTML = cnameHtml;
        document.getElementById('sf-cname-instructions').style.display = 'block';
    }

    // Reload stores table
    sfLoadStores();
}

/* ===== Rollback ===== */
async function sfRollback() {
    if (!confirm('<?php echo $this->jsQuoteEscape($this->__('Roll back all completed provisioning steps?')) ?>')) return;

    var btn = document.getElementById('sf-rollback-btn');
    btn.disabled = true;
    btn.querySelector('span').textContent = '<?php echo $this->jsQuoteEscape($this->__('Rolling back...')) ?>';

    try {
        var r = await mahoFetch('<?php echo $this->getRollbackUrl() ?>', { method: 'POST' });
        if (r.success) {
            alert(r.message || '<?php echo $this->jsQuoteEscape($this->__('Rollback complete.')) ?>');
            sfReset();
        } else {
            alert(r.error || '<?php echo $this->jsQuoteEscape($this->__('Rollback failed.')) ?>');
        }
    } catch (e) {
        alert(e.message || 'Request failed');
    }

    btn.disabled = false;
    btn.querySelector('span').textContent = '<?php echo $this->jsQuoteEscape($this->__('Rollback')) ?>';
}

/* ===== Reset wizard ===== */
function sfReset() {
    sfWizard.currentStep = 1;
    sfWizard.provisioning = false;
    sfWizard.formData = {};

    document.getElementById('sf-store-name').value = '';
    document.getElementById('sf-store-code').value = '';
    document.getElementById('sf-subdomain').value = '';
    document.getElementById('sf-zone').selectedIndex = 0;
    document.getElementById('sf-maho-store').selectedIndex = 0;
    document.getElementById('sf-domain-preview').style.display = 'none';
    document.getElementById('sf-cname-instructions').style.display = 'none';

    sfGoStep(1);
}

/* ===== Copy to clipboard ===== */
function sfCopy(elementId) {
    var text = document.getElementById(elementId).textContent;
    navigator.clipboard.writeText(text).then(function() {
        var btn = document.getElementById(elementId).nextElementSibling;
        var orig = btn.textContent;
        btn.textContent = '<?php echo $this->jsQuoteEscape($this->__('Copied!')) ?>';
        setTimeout(function() { btn.textContent = orig; }, 1500);
    });
}

/* ===== Registered Stores Table ===== */
async function sfLoadStores() {
    var loading = document.getElementById('sf-stores-loading');
    var empty = document.getElementById('sf-stores-empty');
    var table = document.getElementById('sf-stores-table');
    var tbody = document.getElementById('sf-stores-tbody');

    loading.style.display = 'block';
    empty.style.display = 'none';
    table.style.display = 'none';

    try {
        var r = await mahoFetch('<?php echo $this->getListStoresUrl() ?>');
        loading.style.display = 'none';

        if (!r.success || !r.stores || r.stores.length === 0) {
            empty.style.display = 'block';
            return;
        }

        tbody.innerHTML = '';
        r.stores.forEach(function(s) {
            var tr = document.createElement('tr');
            tr.innerHTML = '<td>' + escapeHtml(s.name || '') + '</td>'
                + '<td><code>' + escapeHtml(s.code || '') + '</code></td>'
                + '<td><a href="' + escapeAttr(s.url || '') + '" target="_blank">' + escapeHtml(s.url || '') + '</a></td>'
                + '<td><button type="button" class="scalable" onclick="sfRemoveStore(\'' + escapeAttr(s.code || '') + '\')"><span><?php echo $this->jsQuoteEscape($this->__('Remove')) ?></span></button></td>';
            tbody.appendChild(tr);
        });
        table.style.display = 'table';
    } catch (e) {
        loading.style.display = 'none';
        empty.textContent = e.message || 'Failed to load stores';
        empty.style.display = 'block';
    }
}

async function sfRemoveStore(code) {
    if (!confirm('<?php echo $this->jsQuoteEscape($this->__('Remove this store from the registry?')) ?>\n\nStore code: ' + code)) return;

    try {
        var r = await mahoFetch('<?php echo $this->getRemoveStoreUrl() ?>', {
            method: 'POST',
            body: new URLSearchParams({ store_code: code })
        });

        if (r.success) {
            sfLoadStores();
        } else {
            alert(r.error || 'Remove failed');
        }
    } catch (e) {
        alert(e.message || 'Request failed');
    }
}

/* ===== Utility ===== */
function buildFormBody(data) {
    var params = new URLSearchParams();
    Object.keys(data).forEach(function(k) {
        params.set(k, data[k]);
    });
    return params;
}

function escapeHtml(str) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
}

function escapeAttr(str) {
    return str.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

/* ===== Init ===== */
sfLoadZones();
sfLoadStores();
</script>
